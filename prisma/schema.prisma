generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum CaseStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(USER)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientCases PatientCase[]

  @@map("users")
}

model PatientCase {
  id               String     @id @default(cuid())
  userId           String
  ficha            Json
  persona          String
  status           CaseStatus @default(IN_PROGRESS)
  patientMessages  Json       @default("[]")
  labMessages      Json       @default("[]")
  physicalMessages Json       @default("[]")
  evaluation       Json?
  completedAt      DateTime?
  createdAt        DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("patient_cases")
}
